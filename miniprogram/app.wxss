page {
  min-height: 100vh;
  background: #f7f4ec;
  color: #17211b;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

.page {
  padding: 28rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 28rpx 0 18rpx;
}

.muted {
  color: #667085;
}

.card {
  background: #fffdf7;
  border: 1rpx solid #ece4d2;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 30rpx rgba(32, 43, 35, 0.06);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.btn {
  border-radius: 999rpx;
  background: #0f5132;
  color: #fff;
  font-size: 28rpx;
  padding: 0 28rpx;
  height: 76rpx;
  line-height: 76rpx;
}

.btn.secondary {
  background: #fffdf7;
  color: #0f5132;
  border: 1rpx solid #0f5132;
}

.btn.warning {
  background: #b7791f;
}

.price {
  color: #c2410c;
  font-weight: 700;
}

.pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  background: #e7f2eb;
  color: #0f5132;
  font-size: 24rpx;
}

.input,
.textarea,
.picker {
  background: #fffdf7;
  border: 1rpx solid #ded6c6;
  border-radius: 12rpx;
  padding: 18rpx;
  box-sizing: border-box;
  min-height: 76rpx;
}

.textarea {
  min-height: 150rpx;
}

.empty {
  text-align: center;
  color: #667085;
  padding: 80rpx 20rpx;
}
