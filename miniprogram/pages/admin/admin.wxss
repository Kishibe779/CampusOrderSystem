.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  text-align: center;
}
.stat-num { color: #0f5132; font-size: 38rpx; font-weight: 900; }

.verify-row { display: flex; gap: 14rpx; }
.code-input { flex: 1; }
.verify-btn { width: 150rpx; }

.order-no { font-weight: 800; }
.action-row { margin-top: 18rpx; justify-content: flex-start; }
.small { width: 140rpx; height: 56rpx; line-height: 56rpx; font-size: 24rpx; padding: 0; }

/* 菜品行 */
.dish-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
}
.dish-thumb {
  width: 80rpx; height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  object-fit: cover;
}
.dish-thumb-placeholder {
  background: #f0ece0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.dish-meta { flex: 1; min-width: 0; }
.dish-actions { display: flex; align-items: center; gap: 6rpx; flex-shrink: 0; }

/* 弹窗 */
.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.modal-content {
  background: #fffdf7;
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
}

.dish-img-upload {
  width: 200rpx; height: 200rpx;
  margin: 0 auto 20rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #ccc;
  overflow: hidden;
}
.upload-preview { width: 100%; height: 100%; object-fit: cover; }
.upload-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  color: #999; font-size: 26rpx;
}

.form-row { display: flex; gap: 14rpx; margin: 14rpx 0; }
.half { flex: 1; }
.cats { flex-wrap: wrap; }
.cat-tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f0ece0;
  color: #667085;
  font-size: 24rpx;
}
.cat-tag.active { background: #0f5132; color: #fff; }

.form-btns { display: flex; gap: 16rpx; margin-top: 24rpx; }
