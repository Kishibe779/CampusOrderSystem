.hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #0f5132, #2f7d4f);
  color: #fff;
  border-radius: 24rpx;
  padding: 34rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.82);
}

.group-btn {
  width: 140rpx;
  color: #0f5132;
}

.search-bar {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.search-input {
  flex: 1;
  background: #fffdf7;
  border: 1rpx solid #ece4d2;
  border-radius: 999rpx;
  padding: 0 28rpx;
  height: 76rpx;
}

.search-btn {
  width: 140rpx;
}

.categories {
  white-space: nowrap;
  margin: 8rpx 0 24rpx;
}

.category {
  display: inline-block;
  padding: 14rpx 26rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #667085;
  border: 1rpx solid #ece4d2;
}

.category.active {
  background: #0f5132;
  color: #fff;
}

.dish-card {
  display: flex;
  gap: 22rpx;
}

.dish-image {
  width: 154rpx;
  height: 154rpx;
  border-radius: 20rpx;
  background: #f1d59b;
  color: #7a3e12;
  font-size: 64rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 31rpx;
  font-weight: 700;
}

.dish-desc {
  margin: 10rpx 0 14rpx;
  line-height: 1.45;
}

.pill {
  margin-right: 8rpx;
}

.stock-row {
  margin-top: 18rpx;
}

.add-btn {
  width: 170rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0;
}
