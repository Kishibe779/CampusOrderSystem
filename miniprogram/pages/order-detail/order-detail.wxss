.order-title {
  font-weight: 800;
  font-size: 32rpx;
}

.pickup {
  text-align: center;
}

.pickup-code {
  font-size: 84rpx;
  font-weight: 900;
  letter-spacing: 10rpx;
  color: #0f5132;
  margin: 20rpx 0;
}

.line {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0eadc;
}

.total {
  margin-top: 18rpx;
  font-weight: 800;
}

.timeline-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 16rpx 0;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0f5132;
}

.receipt text {
  white-space: pre-wrap;
  line-height: 1.6;
}
