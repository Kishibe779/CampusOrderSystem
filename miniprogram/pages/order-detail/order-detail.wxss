/* 主题色 */
.theme-green .tl-item.done .tl-dot { background: #0f5132; }
.theme-green .tl-item.done .tl-line { background: #0f5132; }
.theme-green .code-card { background: linear-gradient(135deg, #0f5132, #1a6b3c); }

.theme-blue .tl-item.done .tl-dot { background: #1e40af; }
.theme-blue .tl-item.done .tl-line { background: #1e40af; }
.theme-blue .code-card { background: linear-gradient(135deg, #1e40af, #2563eb); }

.order-no { font-weight: 800; font-size: 30rpx; }
.type-tag { font-size: 22rpx; color: #667085; margin-top: 4rpx; display: inline-block; }
.status-pill { font-size: 24rpx; }

.code-card {
  text-align: center;
  color: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
}
.code-label { font-size: 24rpx; opacity: 0.7; }
.code-value {
  font-size: 88rpx;
  font-weight: 900;
  letter-spacing: 14rpx;
  margin: 12rpx 0;
}
.code-tip { font-size: 22rpx; opacity: 0.8; }

.hint-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
}
.hint-icon { font-size: 40rpx; }
.hint-title { font-weight: 700; color: #c2410c; margin-bottom: 4rpx; }

.addr-line { font-weight: 700; margin-bottom: 4rpx; }
.line { padding: 12rpx 0; border-bottom: 1rpx solid #f0eadc; }
.total { margin-top: 18rpx; font-weight: 800; }

/* 时间线 */
.timeline { padding: 8rpx 0; }
.tl-item { display: flex; gap: 20rpx; padding-bottom: 6rpx; }
.tl-left { display: flex; flex-direction: column; align-items: center; width: 44rpx; }
.tl-dot {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #e8e0cc;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: #fff; flex-shrink: 0;
}
.tl-item.done .tl-dot { font-weight: 700; }
.tl-line { width: 4rpx; flex: 1; min-height: 36rpx; background: #e8e0cc; margin: 6rpx 0; }
.tl-text { padding-top: 4rpx; flex: 1; }
.tl-label { font-size: 28rpx; font-weight: 600; color: #bfb8a2; }
.tl-item.done .tl-label { color: #17211b; }
.tl-time { font-size: 22rpx; margin-top: 2rpx; }

.receipt text { white-space: pre-wrap; line-height: 1.6; }

.actions { margin-top: 8rpx; }
.actions .btn { margin-bottom: 20rpx; }
.cancel-btn { background: #fff !important; color: #dc2626 !important; border: 1rpx solid #fecaca !important; }
