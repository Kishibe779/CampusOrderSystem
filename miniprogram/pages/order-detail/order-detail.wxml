<view class="page theme-{{theme}}" wx:if="{{order}}">
  <view class="card order-header">
    <view class="row">
      <view>
        <view class="order-no">{{order.orderNo}}</view>
        <text class="type-tag">{{order.orderType === 'delivery' ? '🚀 送餐' : order.orderType === 'group' ? '👥 团餐' : '🏠 自取'}}</text>
      </view>
      <text class="pill status-pill">{{statusLabel}}</text>
    </view>
    <view class="muted" style="margin-top:8rpx">{{order.createdAt}}</view>
  </view>

  <!-- 自取：取餐码 -->
  <view class="card code-card" wx:if="{{order.pickupCode}}">
    <view class="code-label">取餐码</view>
    <view class="code-value">{{order.pickupCode}}</view>
    <view class="code-tip">到食堂窗口出示给管理员核销</view>
  </view>

  <!-- 自取待取餐提示 -->
  <view class="card hint-card" wx:if="{{order.orderType !== 'delivery' && order.status === 'ready'}}">
    <text class="hint-icon">📢</text>
    <view>
      <view class="hint-title">餐品已备好，请取餐</view>
      <view class="muted">前往食堂窗口出示取餐码，管理员核销后即可取餐</view>
    </view>
  </view>

  <!-- 订单明细 -->
  <view class="card">
    <view class="section-title">订单明细</view>
    <view class="row line" wx:for="{{order.items}}" wx:key="id">
      <view>{{item.name}} x{{item.quantity}}</view>
      <view>¥{{item.price * item.quantity}}</view>
    </view>
    <view class="row total">
      <view>合计</view>
      <view class="price">¥{{order.totalAmount}}</view>
    </view>
  </view>

  <!-- 送餐地址 -->
  <view class="card" wx:if="{{order.orderType === 'delivery' && order.address}}">
    <view class="section-title">送餐地址</view>
    <view class="addr-line">{{order.address.name}}  {{order.address.phone}}</view>
    <view class="muted">{{order.address.detail}}</view>
  </view>

  <!-- 进度条 -->
  <view class="card" wx:if="{{showProgress}}">
    <view class="section-title">订单进度</view>
    <view class="timeline">
      <view class="tl-item {{activeStep >= index ? 'done' : ''}}" wx:for="{{steps}}" wx:key="status">
        <view class="tl-left">
          <view class="tl-dot">{{activeStep >= index ? '✓' : ''}}</view>
          <view class="tl-line" wx:if="{{index < steps.length - 1}}"></view>
        </view>
        <view class="tl-text">
          <view class="tl-label">{{item.label}}</view>
          <view class="tl-time muted" wx:if="{{activeStep >= index}}">{{index === 0 ? '已完成' : index <= activeStep ? '已完成' : ''}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 电子小票 -->
  <view class="card receipt" wx:if="{{order.status !== 'cancelled' && order.status !== 'unpaid'}}">
    <view class="section-title">电子小票</view>
    <text selectable>{{receipt}}</text>
  </view>

  <!-- 操作按钮区 -->
  <view class="actions">
    <button wx:if="{{order.status === 'unpaid' || order.status === 'paid'}}" class="btn cancel-btn" bindtap="cancelOrder">取消订单</button>
    <button wx:if="{{order.status === 'delivered'}}" class="btn" bindtap="confirmReceive">确认收货</button>
    <button wx:if="{{order.orderType !== 'delivery' && order.status === 'picked'}}" class="btn" bindtap="confirmReceive">确认已取餐</button>
    <button wx:if="{{order.status === 'completed'}}" class="btn secondary" bindtap="goReview">评价订单</button>
  </view>
</view>
