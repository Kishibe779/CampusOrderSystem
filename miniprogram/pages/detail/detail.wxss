.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 140rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  object-fit: cover;
}

.name {
  font-size: 42rpx;
  font-weight: 800;
}

.tags {
  margin-top: 18rpx;
}

.tags .pill {
  margin-right: 10rpx;
}

.body {
  line-height: 1.65;
  color: #34433a;
}

.fixed {
  margin-top: 32rpx;
}
