.cover {
  height: 360rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #f1d59b, #e57f47);
  color: #7a3e12;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
  font-weight: 900;
  margin-bottom: 24rpx;
}

.name {
  font-size: 42rpx;
  font-weight: 800;
}

.tags {
  margin-top: 18rpx;
}

.tags .pill {
  margin-right: 10rpx;
}

.body {
  line-height: 1.65;
  color: #34433a;
}

.fixed {
  margin-top: 32rpx;
}
