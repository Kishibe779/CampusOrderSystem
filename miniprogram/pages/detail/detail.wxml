<view class="page" wx:if="{{dish}}">
  <view class="cover">{{dish.initial}}</view>
  <view class="card detail">
    <view class="row">
      <view class="name">{{dish.name}}</view>
      <view class="price">¥{{dish.price}}</view>
    </view>
    <view class="muted">评分 {{dish.rating}} · 月售 {{dish.sales}} · 库存 {{dish.stock}}</view>
    <view class="tags">
      <text class="pill" wx:for="{{dish.tags}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="section-title">菜品描述</view>
    <view class="body">{{dish.desc}}</view>
    <view class="section-title">配料</view>
    <view class="body">{{dish.ingredients}}</view>
    <view class="section-title">营养提示</view>
    <view class="body">{{dish.nutrition}}</view>
  </view>
  <button class="btn fixed" bindtap="addCart">加入购物车</button>
</view>
