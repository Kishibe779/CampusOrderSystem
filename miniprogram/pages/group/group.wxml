<view class="page">
  <view class="card">
    <view class="section-title">取餐方式</view>
    <radio-group bindchange="onTypeChange">
      <label class="choice"><radio value="pickup" checked="{{orderType === 'pickup'}}" color="#0f5132" />到店自取</label>
      <label class="choice"><radio value="delivery" checked="{{orderType === 'delivery'}}" color="#0f5132" />配送到指定地点</label>
    </radio-group>

    <view wx:if="{{orderType === 'delivery'}}" style="margin-top:18rpx">
      <input class="input" placeholder="收货人/单位" value="{{form.orgName}}" data-field="orgName" bindinput="onInput" />
      <input class="input mt" type="number" placeholder="联系电话" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
      <textarea class="textarea mt" placeholder="配送地址（楼栋、房间号等）" value="{{form.address}}" data-field="address" bindinput="onInput"></textarea>
    </view>
  </view>

  <view class="card">
    <view class="section-title">团餐信息</view>
    <input wx:if="{{orderType !== 'delivery'}}" class="input" placeholder="组织方/班级/接待单位" value="{{form.orgName}}" data-field="orgName" bindinput="onInput" />
    <input class="input mt" type="number" placeholder="就餐人数" value="{{form.peopleCount}}" data-field="peopleCount" bindinput="onInput" />
    <picker mode="date" bindchange="onDate">
      <view class="picker mt">用餐日期：{{form.date || '请选择'}}</view>
    </picker>
    <picker mode="time" bindchange="onTime">
      <view class="picker mt">用餐时间：{{form.time || '请选择'}}</view>
    </picker>
    <textarea class="textarea mt" placeholder="忌口、发票、名单等特殊要求" value="{{form.note}}" data-field="note" bindinput="onInput"></textarea>
  </view>

  <view class="card">
    <view class="section-title">推荐套餐</view>
    <radio-group bindchange="selectPackage">
      <label class="choice" wx:for="{{packages}}" wx:key="name">
        <radio value="{{item.name}}" checked="{{form.packageName === item.name}}" color="#0f5132" />
        {{item.name}} · ¥{{item.price}}/人 · {{item.desc}}
      </label>
    </radio-group>
  </view>

  <button class="btn" bindtap="submit">提交团餐预订</button>
</view>
