.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.brand {
  text-align: center;
  margin-bottom: 52rpx;
}

.logo {
  width: 132rpx;
  height: 132rpx;
  line-height: 132rpx;
  margin: 0 auto 24rpx;
  border-radius: 36rpx;
  background: #0f5132;
  color: #fff;
  font-size: 56rpx;
  font-weight: 800;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
}

.subtitle {
  color: #667085;
  margin-top: 16rpx;
}

.role {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
}

.role-name {
  font-weight: 700;
}

.login-btn {
  margin-top: 28rpx;
}
