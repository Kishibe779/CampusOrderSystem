.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  display: flex;
  background: #fffdf7;
  border-top: 1rpx solid #ece4d2;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #bfb8a2;
  transition: color 0.2s;
}

.tab-item.active {
  color: #0f5132;
}

.tab-icon-wrap {
  position: relative;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  background: #dc2626;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  border-radius: 999rpx;
  padding: 0 8rpx;
  text-align: center;
  box-sizing: border-box;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 500;
}
