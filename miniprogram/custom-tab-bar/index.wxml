<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon-wrap">
      <text class="tab-icon">{{item.icon}}</text>
      <view wx:if="{{index === 1 && cartCount > 0}}" class="badge">{{cartCount > 99 ? '99+' : cartCount}}</view>
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
